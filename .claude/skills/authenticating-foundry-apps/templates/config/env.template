# ==========================================================================
# Foundry Environment Configuration
# ==========================================================================
#
# This file contains configuration for connecting to your Foundry environment.
# Uncomment ONE deployment section below that matches your environment.
#
# To switch environments:
# 1. Comment out the current active section
# 2. Uncomment the section for your target environment
# 3. Update the host values for that environment
# 4. Restart your dev server (npm run dev)
#
# ==========================================================================

# App Credentials (same for all environments)
# Get these from your Foundry Console -> App -> Settings
VITE_FOUNDRY_APP_KEY=your_app_key_here
VITE_FOUNDRY_APP_SECRET=your_app_secret_here

# --------------------------------------------------------------------------
# CLOUD DEPLOYMENT
# --------------------------------------------------------------------------
{{CLOUD_SECTION_COMMENT}}
#
# How to find these values for a different cloud environment:
# - Download Swagger from your target Foundry environment
# - VITE_FOUNDRY_AUTH_HOST: Open any identity service .json file -> "host" field
# - VITE_FOUNDRY_SERVICE_HOST: Open any integration/object service .json file -> "host" field
# --------------------------------------------------------------------------

{{CLOUD_COMMENT_PREFIX}}VITE_FOUNDRY_AUTH_HOST={{CLOUD_AUTH_HOST}}
{{CLOUD_COMMENT_PREFIX}}VITE_FOUNDRY_SERVICE_HOST={{CLOUD_SERVICE_HOST}}

# --------------------------------------------------------------------------
# ON-PREMISE DEPLOYMENT
# --------------------------------------------------------------------------
{{ONPREM_SECTION_COMMENT}}
#
# Pattern for on-premise:
# - VITE_FOUNDRY_AUTH_HOST: {server} (without /authService/ - that's added by the client)
# - VITE_FOUNDRY_SERVICE_HOST: {server}/services
#
# Example:
# - Auth: my-company-foundry.net
# - Services: my-company-foundry.net/services
# --------------------------------------------------------------------------

{{ONPREM_COMMENT_PREFIX}}VITE_FOUNDRY_AUTH_HOST={{ONPREM_AUTH_HOST}}
{{ONPREM_COMMENT_PREFIX}}VITE_FOUNDRY_SERVICE_HOST={{ONPREM_SERVICE_HOST}}
